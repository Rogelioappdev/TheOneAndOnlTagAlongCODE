  // Slide 13: Planning Style
  if (currentSlide === 13) {
    const planningStyles = [
      { id: 'planner', label: 'Planner', emoji: '📋' },
      { id: 'spontaneous', label: 'Spontaneous', emoji: '🎲' },
      { id: 'flexible', label: 'Flexible', emoji: '🌊' },
    ];

    return (
      <View className="flex-1 bg-black">
        <PremiumBackground />
        <SafeAreaView className="flex-1" edges={['top', 'bottom']}>
          <View className="flex-1 px-6 justify-center">
            <Animated.Text entering={FadeInLeft.delay(100).springify()} className="text-4xl font-bold text-white mb-2">Planning vs Spontaneous?</Animated.Text>
            <Animated.Text entering={FadeInLeft.delay(200).springify()} className="text-lg text-emerald-400 mb-12">
              How do you approach travel?
            </Animated.Text>

            {planningStyles.map((style, index) => (
              <Animated.View key={style.id} entering={FadeInRight.delay(300 + index * 150).springify()}>
                <Pressable
                  onPress={async () => {
                    await playHeavy();
                    setData({ ...data, planningStyle: style.id as 'planner' | 'spontaneous' | 'flexible' });
                  }}
                  className={`mb-4 py-6 px-5 rounded-2xl border flex-row items-center ${
                    data.planningStyle === style.id
                      ? 'bg-emerald-500 border-emerald-400'
                      : 'bg-white/5 border-white/10'
                  } active:opacity-80`}
                >
                  <Text className="text-4xl mr-4">{style.emoji}</Text>
                  <Text className="text-white text-xl font-semibold flex-1">{style.label}</Text>
                </Pressable>
              </Animated.View>
            ))}
          </View>

          <Animated.View entering={FadeInUp.delay(800).springify()} className="px-6 pb-6">
            <Animated.View style={buttonAnimatedStyle}>
              <Pressable
                onPress={handleContinue}
                disabled={!canContinue()}
                className={`py-5 rounded-2xl ${canContinue() ? 'bg-emerald-500 active:opacity-80' : 'bg-white/5'}`}
              >
                <Text className={`text-lg font-semibold text-center ${canContinue() ? 'text-white' : 'text-gray-600'}`}>
                  Continue
                </Text>
              </Pressable>
            </Animated.View>
          </Animated.View>
        </SafeAreaView>
      </View>
    );
  }

  // Slide 14: Travel Experience
  if (currentSlide === 14) {
    const experienceLevels = [
      { id: 'beginner', label: '🌱 Beginner', desc: 'Just starting my travel journey' },
      { id: 'intermediate', label: '🎒 Intermediate', desc: 'Been to a few places, eager for more' },
      { id: 'experienced', label: '🗺️ Experienced', desc: 'Traveled extensively, confident explorer' },
      { id: 'expert', label: '🏆 Expert', desc: 'Seasoned traveler, can guide others' },
    ];

    return (
      <View className="flex-1 bg-black">
        <PremiumBackground />
        <SafeAreaView className="flex-1" edges={['top', 'bottom']}>
          <View className="flex-1 px-6 justify-center">
            <Animated.Text entering={FadeInLeft.delay(100).springify()} className="text-4xl font-bold text-white mb-2">What's your travel experience?</Animated.Text>
            <Animated.Text entering={FadeInLeft.delay(200).springify()} className="text-lg text-emerald-400 mb-12">
              Where are you on your journey?
            </Animated.Text>

            {experienceLevels.map((level, index) => (
              <Animated.View key={level.id} entering={FadeInRight.delay(300 + index * 120).springify()}>
                <Pressable
                  onPress={async () => {
                    await playHeavy();
                    setData({ ...data, experience: level.id as 'beginner' | 'intermediate' | 'experienced' | 'expert' });
                  }}
                  className={`mb-4 py-5 px-5 rounded-2xl border ${
                    data.experience === level.id
                      ? 'bg-emerald-500 border-emerald-400'
                      : 'bg-white/5 border-white/10'
                  } active:opacity-80`}
                >
                  <Text className="text-white text-xl font-semibold mb-1">{level.label}</Text>
                  <Text className="text-gray-400 text-sm">{level.desc}</Text>
                </Pressable>
              </Animated.View>
            ))}
          </View>

          <Animated.View entering={FadeInUp.delay(900).springify()} className="px-6 pb-6">
            <Animated.View style={buttonAnimatedStyle}>
              <Pressable
                onPress={handleContinue}
                disabled={!canContinue()}
                className={`py-5 rounded-2xl ${canContinue() ? 'bg-emerald-500 active:opacity-80' : 'bg-white/5'}`}
              >
                <Text className={`text-lg font-semibold text-center ${canContinue() ? 'text-white' : 'text-gray-600'}`}>
                  Continue
                </Text>
              </Pressable>
            </Animated.View>
          </Animated.View>
        </SafeAreaView>
      </View>
    );
  }

  // Slide 15: Calculating Matches
  if (currentSlide === 15) {
    return (
      <View className="flex-1 bg-black">
        <PremiumBackground />
        <SafeAreaView className="flex-1" edges={['top', 'bottom']}>
          <View className="flex-1 justify-center items-center px-6">
            {!calculationDone ? (
              <>
                <Animated.View entering={ZoomIn.springify()} className="mb-8">
                  <View className="bg-emerald-500/10 p-8 rounded-full">
                    <Animated.View style={animatedStyle}>
                      <Globe size={80} color="#10b981" strokeWidth={1.5} />
                    </Animated.View>
                  </View>
                </Animated.View>

                <Animated.Text entering={FadeInUp.delay(200).springify()} className="text-3xl font-bold text-white text-center mb-4">
                  Finding Your Matches
                </Animated.Text>

                <Animated.Text entering={FadeInUp.delay(400).springify()} className="text-lg text-gray-400 text-center mb-8">
                  Analyzing your travel preferences...
                </Animated.Text>

                <Animated.View entering={FadeIn.delay(600)} className="w-full px-4">
                  <View className="bg-white/10 h-3 rounded-full overflow-hidden">
                    <Animated.View
                      className="bg-emerald-500 h-full rounded-full"
                      style={calculationProgressStyle}
                    />
                  </View>
                </Animated.View>

                <Animated.Text entering={FadeIn.delay(800)} className="text-gray-500 text-sm mt-4">
                  This may take a moment...
                </Animated.Text>
              </>
            ) : (
              <>
                <Animated.View entering={BounceIn} className="mb-6">
                  <View className="bg-emerald-500/20 p-6 rounded-full">
                    <Check size={60} color="#10b981" strokeWidth={2} />
                  </View>
                </Animated.View>

                <Animated.Text entering={FadeInUp.delay(200).springify()} className="text-5xl font-bold text-emerald-400 mb-2">
                  {matchCount.toLocaleString()}
                </Animated.Text>

                <Animated.Text entering={FadeInUp.delay(400).springify()} className="text-2xl font-semibold text-white mb-4">
                  Travelers Match With You!
                </Animated.Text>

                <Animated.Text entering={FadeInUp.delay(600).springify()} className="text-base text-gray-400 text-center mb-12 px-4">
                  Based on your preferences, travel style, and destinations
                </Animated.Text>

                <Animated.View entering={FadeInUp.delay(800).springify()} className="w-full px-4">
                  <Pressable
                    onPress={async () => {
                      await playHeavy();
                      handleContinue();
                    }}
                    className="bg-emerald-500 py-5 rounded-2xl active:opacity-80"
                  >
                    <Text className="text-white text-lg font-semibold text-center">
                      Continue
                    </Text>
                  </Pressable>
                </Animated.View>
              </>
            )}
          </View>
        </SafeAreaView>
      </View>
    );
  }

  // Slide 16: Profile Photos
  if (currentSlide === 16) {
    const pickImageFromLibrary = async () => {
      const { status } = await ImagePicker.requestMediaLibraryPermissionsAsync();

      if (status !== 'granted') {
        Alert.alert(
          'Permission Required',
          'Please allow access to your photo library to add profile pictures.',
          [{ text: 'OK' }]
        );
        return;
      }

      const result = await ImagePicker.launchImageLibraryAsync({
        mediaTypes: ['images'],
        allowsEditing: true,
        aspect: [3, 4],
        quality: 0.8,
      });

      if (!result.canceled && result.assets[0]) {
        if (profilePhotos.length < 4) {
          setProfilePhotos([...profilePhotos, result.assets[0].uri]);
          playHeavy();
        }
      }
      setShowPhotoOptions(false);
    };

    const takePhoto = async () => {
      const { status } = await ImagePicker.requestCameraPermissionsAsync();

      if (status !== 'granted') {
        Alert.alert(
          'Permission Required',
          'Please allow access to your camera to take a profile picture.',
          [{ text: 'OK' }]
        );
        return;
      }

      const result = await ImagePicker.launchCameraAsync({
        mediaTypes: ['images'],
        allowsEditing: true,
        aspect: [3, 4],
        quality: 0.8,
        cameraType: ImagePicker.CameraType.front,
      });

      if (!result.canceled && result.assets[0]) {
        if (profilePhotos.length < 4) {
          setProfilePhotos([...profilePhotos, result.assets[0].uri]);
          playHeavy();
        }
      }
      setShowPhotoOptions(false);
    };

    const removePhoto = (index: number) => {
      setProfilePhotos(profilePhotos.filter((_, i) => i !== index));
      playSoft();
    };

    const handleAddPhoto = () => {
      if (profilePhotos.length >= 4) return;
      setShowPhotoOptions(true);
    };

    return (
      <View className="flex-1 bg-black">
        <PremiumBackground />
        <SafeAreaView className="flex-1" edges={['top', 'bottom']}>
          <View className="flex-1">
            {/* Header */}
            <View className="px-6 pt-6 pb-4">
              <Animated.Text entering={FadeInDown.delay(100).springify()} className="text-4xl font-bold text-white mb-2">
                Add Your Photos
              </Animated.Text>
              <Animated.Text entering={FadeInDown.delay(200).springify()} className="text-base text-gray-400">
                Other travelers will see your profile pictures
              </Animated.Text>
            </View>

            {/* Photo requirement badge */}
            <Animated.View entering={FadeIn.delay(300)} className="mx-6 mb-6">
              <View className={`flex-row items-center px-4 py-3 rounded-xl ${profilePhotos.length >= 3 ? 'bg-emerald-500/20' : 'bg-amber-500/20'}`}>
                {profilePhotos.length >= 3 ? (
                  <Check size={20} color="#10b981" strokeWidth={2} />
                ) : (
                  <CameraIcon size={20} color="#f59e0b" strokeWidth={2} />
                )}
                <Text className={`ml-2 font-medium ${profilePhotos.length >= 3 ? 'text-emerald-400' : 'text-amber-400'}`}>
                  {profilePhotos.length >= 3
                    ? 'Looking great!'
                    : `Minimum 3 photos required (${profilePhotos.length}/3)`
                  }
                </Text>
              </View>
            </Animated.View>

            {/* Photo grid */}
            <Animated.View entering={FadeInUp.delay(400).springify()} className="flex-1 px-6">
              <View className="flex-row flex-wrap justify-between">
                {[0, 1, 2, 3].map((index) => (
                  <Pressable
                    key={index}
                    onPress={() => profilePhotos[index] ? removePhoto(index) : handleAddPhoto()}
                    className="mb-4"
                    style={{ width: (width - 60) / 2 }}
                  >
                    <View
                      className={`aspect-[3/4] rounded-2xl overflow-hidden ${
                        profilePhotos[index] ? 'border-2 border-emerald-500' : 'border-2 border-dashed border-white/20'
                      }`}
                    >
                      {profilePhotos[index] ? (
                        <View className="flex-1">
                          <Image
                            source={{ uri: profilePhotos[index] }}
                            style={{ width: '100%', height: '100%' }}
                            resizeMode="cover"
                          />
                          <View className="absolute top-2 right-2 bg-black/60 rounded-full p-1">
                            <X size={16} color="#ef4444" strokeWidth={2} />
                          </View>
                          {index === 0 && (
                            <View className="absolute bottom-2 left-2 bg-emerald-500 px-2 py-1 rounded-lg">
                              <Text className="text-white text-xs font-semibold">Main</Text>
                            </View>
                          )}
                        </View>
                      ) : (
                        <View className="flex-1 items-center justify-center bg-white/5">
                          <View className="bg-white/10 p-4 rounded-full mb-2">
                            <CameraIcon size={24} color="#6b7280" strokeWidth={1.5} />
                          </View>
                          <Text className="text-gray-500 text-sm">Add Photo</Text>
                        </View>
                      )}
                    </View>
                  </Pressable>
                ))}
              </View>

              <Text className="text-gray-500 text-sm text-center mt-2">
                Tap to add or remove photos
              </Text>
            </Animated.View>

            {/* Continue button */}
            <Animated.View entering={FadeInUp.delay(600).springify()} className="px-6 pb-6">
              <Pressable
                onPress={async () => {
                  await playSuccess();
                  handleContinue();
                }}
                disabled={profilePhotos.length < 3}
                className={`py-5 rounded-2xl ${profilePhotos.length >= 3 ? 'bg-emerald-500 active:opacity-80' : 'bg-white/5'}`}
              >
                <Text className={`text-lg font-semibold text-center ${profilePhotos.length >= 3 ? 'text-white' : 'text-gray-600'}`}>
                  Continue
                </Text>
              </Pressable>
            </Animated.View>
          </View>

          {/* Photo options modal */}
          {showPhotoOptions && (
            <Pressable
              className="absolute inset-0 bg-black/70 justify-end"
              onPress={() => setShowPhotoOptions(false)}
            >
              <Animated.View entering={FadeInUp.springify()} className="bg-neutral-900 rounded-t-3xl p-6 pb-10">
                <View className="w-12 h-1 bg-white/20 rounded-full self-center mb-6" />

                <Text className="text-white text-xl font-bold mb-6 text-center">
                  Add Profile Photo
                </Text>

                <Pressable
                  onPress={takePhoto}
                  className="flex-row items-center bg-white/10 p-4 rounded-2xl mb-3 active:opacity-70"
                >
                  <View className="bg-emerald-500/20 p-3 rounded-full mr-4">
                    <CameraIcon size={24} color="#10b981" strokeWidth={2} />
                  </View>
                  <View className="flex-1">
                    <Text className="text-white font-semibold text-base">Take Photo</Text>
                    <Text className="text-gray-400 text-sm">Use your camera</Text>
                  </View>
                </Pressable>

                <Pressable
                  onPress={pickImageFromLibrary}
                  className="flex-row items-center bg-white/10 p-4 rounded-2xl mb-6 active:opacity-70"
                >
                  <View className="bg-emerald-500/20 p-3 rounded-full mr-4">
                    <ImageIcon size={24} color="#10b981" strokeWidth={2} />
                  </View>
                  <View className="flex-1">
                    <Text className="text-white font-semibold text-base">Choose from Library</Text>
                    <Text className="text-gray-400 text-sm">Select from your photos</Text>
                  </View>
                </Pressable>

                <Pressable
                  onPress={() => setShowPhotoOptions(false)}
                  className="py-4 rounded-2xl border border-white/20 active:opacity-70"
                >
                  <Text className="text-white font-semibold text-center">Cancel</Text>
                </Pressable>
              </Animated.View>
            </Pressable>
          )}
        </SafeAreaView>
      </View>
    );
  }

  // Slide 17: Verify Human Intro
  if (currentSlide === 17) {
    return (
      <View className="flex-1 bg-black">
        <PremiumBackground />
        <SafeAreaView className="flex-1" edges={['top', 'bottom']}>
          <View className="flex-1 justify-center items-center px-6">
            <Animated.View entering={ZoomIn.delay(100).springify()} className="mb-8">
              <View className="bg-emerald-500/10 p-8 rounded-full">
                <UserIcon size={80} color="#10b981" strokeWidth={1.5} />
              </View>
            </Animated.View>

            <Animated.Text entering={FadeInUp.delay(200).springify()} className="text-4xl font-bold text-white text-center mb-4">
              Last Step!
            </Animated.Text>

            <Animated.Text entering={FadeInUp.delay(300).springify()} className="text-2xl font-semibold text-emerald-400 text-center mb-6">
              Please verify you're human
            </Animated.Text>

            <Animated.Text entering={FadeInUp.delay(400).springify()} className="text-base text-gray-400 text-center mb-4 px-4">
              For the safety of our community, we verify all members through a quick face scan.
            </Animated.Text>

            <Animated.View entering={FadeIn.delay(500)} className="bg-white/5 rounded-2xl p-4 mb-12">
              <View className="flex-row items-center">
                <View className="bg-emerald-500/20 p-2 rounded-full mr-3">
                  <Check size={16} color="#10b981" strokeWidth={2} />
                </View>
                <Text className="text-gray-300 text-sm flex-1">
                  This will verify your account and unlock all features
                </Text>
              </View>
            </Animated.View>

            <Animated.View entering={FadeInUp.delay(600).springify()} className="w-full">
              <Pressable
                onPress={async () => {
                  await playHeavy();
                  handleContinue();
                }}
                className="bg-emerald-500 py-5 rounded-2xl active:opacity-80"
              >
                <Text className="text-white text-lg font-semibold text-center">
                  Continue to Verification
                </Text>
              </Pressable>
            </Animated.View>

            <Animated.Text entering={FadeIn.delay(700)} className="text-gray-600 text-xs text-center mt-4">
              Your face data is processed securely and never stored
            </Animated.Text>
          </View>
        </SafeAreaView>
      </View>
    );
  }

  // Slide 18: Face Verification
  if (currentSlide === 18) {
    if (!cameraPermission) {
      return (
        <View className="flex-1 bg-black items-center justify-center">
          <ActivityIndicator size="large" color="#10b981" />
        </View>
      );
    }

    if (!cameraPermission.granted) {
      return (
        <View className="flex-1 bg-black">
          <PremiumBackground />
          <SafeAreaView className="flex-1" edges={['top', 'bottom']}>
            <View className="flex-1 px-6 justify-center items-center">
              <Animated.View entering={ZoomIn.delay(100).springify()} className="bg-emerald-500/10 p-6 rounded-full mb-6">
                <CameraIcon size={80} color="#10b981" strokeWidth={1.5} />
              </Animated.View>
              <Animated.Text entering={FadeInUp.delay(300).springify()} className="text-4xl font-bold text-white mb-4 text-center">Face Verification</Animated.Text>
              <Animated.Text entering={FadeInUp.delay(400).springify()} className="text-lg text-gray-400 mb-12 text-center">
                We need to verify you're human for safety and trust
              </Animated.Text>
              <Animated.View entering={FadeInUp.delay(600).springify()}>
                <Pressable
                  onPress={requestCameraPermission}
                  className="bg-emerald-500 px-12 py-5 rounded-2xl active:opacity-80"
                >
                  <Text className="text-white text-lg font-semibold">
                    Allow Camera Access
                  </Text>
                </Pressable>
              </Animated.View>
            </View>
          </SafeAreaView>
        </View>
      );
    }

    return (
      <View className="flex-1 bg-black">
        <CameraView
          style={{
            position: 'absolute',
            top: 0,
            left: 0,
            width: width,
            height: height,
          }}
          facing="front"
        />
        <SafeAreaView style={{ flex: 1 }} edges={['top', 'bottom']}>
          <View style={{ flex: 1 }}>
            {/* Header */}
            <Animated.View entering={FadeInDown.delay(100).springify()} className="px-6 pt-4">
              <Text className="text-white text-2xl font-bold text-center">
                Face Verification
              </Text>
              <Text className="text-gray-300 text-base text-center mt-2">
                Follow the instructions below
              </Text>
            </Animated.View>

            {/* Center instruction */}
            <View className="flex-1 justify-center items-center">
              <Animated.View entering={ZoomIn.delay(300).springify()} className="bg-black/60 px-8 py-6 rounded-3xl border-2 border-emerald-500">
                {data.verified ? (
                  <Animated.View entering={BounceIn} className="items-center">
                    <View className="bg-emerald-500 rounded-full p-4 mb-4">
                      <Check size={60} color="#ffffff" strokeWidth={3} />
                    </View>
                    <Text className="text-white text-2xl font-bold">Verified!</Text>
                    <Text className="text-gray-300 text-base mt-2">You're all set</Text>
                  </Animated.View>
                ) : (
                  <View className="items-center">
                    {verificationStep === 0 && <UserIcon size={60} color="#10b981" strokeWidth={2} />}
                    {verificationStep === 1 && <ArrowUp size={60} color="#10b981" strokeWidth={2} />}
                    {verificationStep === 2 && <ArrowRight size={60} color="#10b981" strokeWidth={2} />}
                    {verificationStep === 3 && <ArrowLeft size={60} color="#10b981" strokeWidth={2} />}
                    <Text className="text-white text-2xl font-bold mt-4">
                      {verificationSteps[verificationStep]}
                    </Text>
                    {isVerifying && (
                      <ActivityIndicator size="large" color="#10b981" style={{ marginTop: 16 }} />
                    )}
                  </View>
                )}
              </Animated.View>
            </View>

            {/* Progress indicators */}
            <View className="px-6 pb-4">
              <View className="flex-row justify-center mb-6">
                {verificationSteps.map((_, index) => (
                  <Animated.View
                    key={index}
                    entering={FadeIn.delay(500 + index * 100)}
                    className={`h-2 w-16 rounded-full mx-1 ${
                      index <= verificationStep ? 'bg-emerald-500' : 'bg-white/20'
                    }`}
                  />
                ))}
              </View>

              {!data.verified ? (
                <Animated.View entering={FadeInUp.delay(700).springify()}>
                  <Pressable
                    onPress={async () => {
                      await playSoft();
                      simulateVerification();
                    }}
                    disabled={isVerifying}
                    className={`py-5 rounded-2xl ${isVerifying ? 'bg-white/10' : 'bg-emerald-500 active:opacity-80'}`}
                  >
                    <Text className="text-white text-lg font-semibold text-center">
                      {isVerifying ? 'Verifying...' : 'Verify Step'}
                    </Text>
                  </Pressable>
                </Animated.View>
              ) : (
                <Animated.View entering={BounceIn}>
                  <Pressable
                    onPress={async () => {
                      await playSuccess();
                      await playSuccess();
                      handleContinue();
                    }}
                    className="bg-emerald-500 py-5 rounded-2xl active:opacity-80"
                  >
                    <Text className="text-white text-lg font-semibold text-center">
                      Complete
                    </Text>
                  </Pressable>
                </Animated.View>
              )}
            </View>
          </View>
        </SafeAreaView>
      </View>
    );
  }

  // Slide 19: Bucket List Builder - Ultra smooth single card swipe
  if (currentSlide === 19) {
    if (currentDestinationIndex >= DESTINATIONS.length) {
      setCurrentDestinationIndex(0);
    }

    const currentDestination = DESTINATIONS[currentDestinationIndex];
    const progress = data.bucketList.length;

    const handleButtonSwipe = (direction: 'left' | 'right') => {
      if (direction === 'right') {
        playHeavy();
      } else {
        playSoft();
      }
      triggerSwipe(direction);
    };

    return (
      <View className="flex-1 bg-black">
        <PremiumBackground />
        <SafeAreaView className="flex-1" edges={['top', 'bottom']}>
          <View className="flex-1">
            {/* Header */}
            <View className="px-6 pt-6 pb-4">
              <Text className="text-4xl font-bold text-white mb-2">Build Your Bucket List</Text>
              <Text className="text-lg text-emerald-400 mb-4">
                Swipe right to add, left to skip
              </Text>
              <View className="flex-row items-center">
                <View className="flex-1 bg-white/10 h-2 rounded-full overflow-hidden">
                  <View
                    className="bg-emerald-500 h-full"
                    style={{ width: `${(progress / 6) * 100}%` }}
                  />
                </View>
                <Text className="text-white font-semibold ml-3">{progress}/6</Text>
              </View>
            </View>

            {/* Single Card - No card behind */}
            <View className="flex-1 items-center justify-center px-5">
              {currentDestination && (
                <GestureDetector gesture={panGesture}>
                  <Animated.View
                    style={[
                      {
                        width: width - 40,
                        height: height * 0.55,
                      },
                      cardAnimatedStyle,
                    ]}
                  >
                    <View className="flex-1 rounded-3xl overflow-hidden bg-neutral-900">
                      <Image
                        source={{ uri: currentDestination.image }}
                        style={{ width: '100%', height: '100%' }}
                        resizeMode="cover"
                      />
                      <LinearGradient
                        colors={['transparent', 'rgba(0,0,0,0.9)']}
                        style={{
                          position: 'absolute',
                          bottom: 0,
                          left: 0,
                          right: 0,
                          height: '50%',
                          justifyContent: 'flex-end',
                          padding: 24,
                        }}
                      >
                        <Text className="text-5xl mb-2">{currentDestination.emoji}</Text>
                        <Text className="text-white text-3xl font-bold">
                          {currentDestination.name}
                        </Text>
                      </LinearGradient>
                    </View>
                  </Animated.View>
                </GestureDetector>
              )}
            </View>

            {/* Action Buttons */}
            <View className="px-6 pb-6 flex-row justify-center items-center">
              <Pressable
                onPress={() => handleButtonSwipe('left')}
                className="bg-white/10 p-6 rounded-full mr-8 active:opacity-70"
              >
                <X size={32} color="#ef4444" strokeWidth={2.5} />
              </Pressable>

              <Pressable
                onPress={() => handleButtonSwipe('right')}
                className="bg-emerald-500 p-6 rounded-full active:opacity-70"
              >
                <Heart size={32} color="#ffffff" strokeWidth={2.5} />
              </Pressable>
            </View>

            {/* Continue Button */}
            {progress >= 6 && (
              <View className="px-6 pb-2">
                <Pressable
                  onPress={async () => {
                    await playSuccess();
                    handleContinue();
                  }}
                  className="bg-emerald-500 py-5 rounded-2xl active:opacity-80"
                >
                  <Text className="text-white text-lg font-semibold text-center">
                    Complete Profile
                  </Text>
                </Pressable>
              </View>
            )}
          </View>
        </SafeAreaView>
      </View>
    );
  }

  return null;
}
