    return (
      <View className="flex-1 bg-black">
        <PremiumBackground />
        <SafeAreaView className="flex-1" edges={['top', 'bottom']}>
          <View className="flex-1 px-6 justify-center">
            <Animated.Text entering={FadeInLeft.delay(100).springify()} className="text-4xl font-bold text-white mb-2">Who do you want to travel with?</Animated.Text>
            <Animated.Text entering={FadeInLeft.delay(200).springify()} className="text-lg text-emerald-400 mb-12">
              Choose your preferred travel companions
            </Animated.Text>

            {travelWithOptions.map((option, index) => (
              <Animated.View key={option.id} entering={FadeInRight.delay(300 + index * 150).springify()}>
                <Pressable
                  onPress={async () => {
                    await playHeavy();
                    setData({ ...data, travelWith: option.id as 'male' | 'female' | 'everyone' });
                  }}
                  className={`mb-4 py-6 px-5 rounded-2xl border flex-row items-center ${
                    data.travelWith === option.id
                      ? 'bg-emerald-500 border-emerald-400'
                      : 'bg-white/5 border-white/10'
                  } active:opacity-80`}
                >
                  <Text className="text-4xl mr-4">{option.emoji}</Text>
                  <Text className="text-white text-xl font-semibold flex-1">
                    {option.label}
                  </Text>
                </Pressable>
              </Animated.View>
            ))}
          </View>

          <Animated.View entering={FadeInUp.delay(800).springify()} className="px-6 pb-6">
            <Animated.View style={buttonAnimatedStyle}>
              <Pressable
                onPress={handleContinue}
                disabled={!canContinue()}
                className={`py-5 rounded-2xl ${canContinue() ? 'bg-emerald-500 active:opacity-80' : 'bg-white/5'}`}
              >
                <Text className={`text-lg font-semibold text-center ${canContinue() ? 'text-white' : 'text-gray-600'}`}>
                  Continue
                </Text>
              </Pressable>
            </Animated.View>
          </Animated.View>
        </SafeAreaView>
      </View>
    );
  }

  // Slide 6: Bio
  if (currentSlide === 6) {
    return (
      <View className="flex-1 bg-black">
        <PremiumBackground />
        <SafeAreaView className="flex-1" edges={['top', 'bottom']}>
          {/* Skip button at top right */}
          <Animated.View entering={FadeIn.delay(500)} className="absolute top-0 right-0 z-10 pt-14 pr-6">
            <Pressable
              onPress={handleContinue}
              className="py-2 px-4 rounded-full bg-white/10 active:opacity-60"
            >
              <Text className="text-white text-base font-medium">Skip</Text>
            </Pressable>
          </Animated.View>

          <View className="flex-1 px-6 justify-center">
            <Animated.View entering={BounceIn.delay(100)} className="flex-row items-center mb-2">
              <Text className="text-4xl mr-3">✍️</Text>
              <Text className="text-4xl font-bold text-white">Tell us about yourself</Text>
            </Animated.View>
            <Animated.Text entering={FadeInLeft.delay(200).springify()} className="text-lg text-emerald-400 mb-8">
              Share what travelers should know about you
            </Animated.Text>

            <Animated.View entering={FadeInUp.delay(400).springify()} className="bg-white/5 border border-white/10 rounded-2xl p-5">
              <View className="flex-row items-center mb-4">
                <Edit3 size={20} color="#10b981" />
                <Text className="text-emerald-400 text-sm font-semibold ml-2">
                  Your Bio (min 20 characters)
                </Text>
              </View>
              <TextInput
                value={data.bio}
                onChangeText={(text) => setData({ ...data, bio: text })}
                placeholder="Tell others about your travel style, interests, what you're looking for in a travel companion..."
                placeholderTextColor="#6b7280"
                className="text-white text-base min-h-40"
                multiline
                textAlignVertical="top"
                maxLength={500}
              />
              <Text className="text-gray-500 text-xs mt-3 text-right">
                {data.bio.length}/500
              </Text>
            </Animated.View>
          </View>

          <Animated.View entering={FadeInUp.delay(600).springify()} className="px-6 pb-6">
            <Animated.View style={buttonAnimatedStyle}>
              <Pressable
                onPress={handleContinue}
                disabled={!canContinue()}
                className={`py-5 rounded-2xl ${canContinue() ? 'bg-emerald-500 active:opacity-80' : 'bg-white/5'}`}
