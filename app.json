{
  "expo": {
    "name": "TagAlong",
    "slug": "tag-along",
    "scheme": "tagalong",
    "version": "17.5",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vibecode.tagalong"
    },
    "android": {
      "package": "com.vibecode.tagalong",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "./plugins/withSwiftConcurrencyFix"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "757e1a72-507c-4f1c-9d60-ec08e5db9605"
      }
    }
  }
}
